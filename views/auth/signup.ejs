<%- include('../includes/head.ejs') %>
</head>

<body>
    <%- include('../includes/navigation.ejs') %>

    <main class="layout-stack">
        <% if (errorMessage) { %>
            <div class="user-message user-message--error"><%= errorMessage %></div>
        <% } %>
        <div class="form-card">
            <form class="form-stack" action="/signup" method="POST" novalidate>
                <div class="form-control">
                    <label for="email">E-Mail</label>
                    <input class="<%= validationErrors.find(e => e.path === 'email') ? 'invalid' : '' %>" type="email" name="email" id="email" value="<%= oldInput.email %>">
                </div>
                <div class="form-control">
                    <label for="password">Password</label>
                    <input class="<%= validationErrors.find(e => e.path === 'password') ? 'invalid' : '' %>" type="password" name="password" id="password" value="<%= oldInput.password %>">
                </div>
                <div class="form-control">
                    <label for="confirmPassword">Confirm Password</label>
                    <input class="<%= validationErrors.find(e => e.path === 'confirmPassword') ? 'invalid' : '' %>" type="password" name="confirmPassword" id="confirmPassword" value="<%= oldInput.confirmPassword %>">
                </div>
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button class="btn-solid" type="submit">Signup</button>
            </form>
        </div>
    </main>
<%- include('../includes/end.ejs') %>