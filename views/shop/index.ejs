<%- include('../includes/head.ejs') %>
</head>

<body>
    <%- include('../includes/navigation.ejs') %>

    <main class="layout-stack">
        <% if (prods.length > 0) { %>
            <div class="product-grid">
                <% for (let product of prods) { %>
                    <article class="product-card">
                        <div class="product-card__image">
                            <img src="/<%= product.imageUrl %>"
                                alt="<%= product.title %>">
                        </div>
                        <div class="product-card__content">
                            <div class="product-card__body">
                                <h1 class="product-card__title"><%= product.title %></h1>
                                <h2 class="product-card__price">$<%= product.price %></h2>
                                <p class="product-card__description"><%= product.description %></p>
                            </div>
                            <div class="product-card__actions">
                                <a href="/products/<%= product._id %>" class="btn">Details</a>
                                <% if (isAuthenticated) { %>
                                    <%- include('../includes/add-to-cart.ejs', {product: product}) %>
                                <% } %>
                            </div>
                        </div>
                    </article>
                <% } %>
            </div>
        <% } else { %>
            <div class="empty-state">
                <p>No products found.</p>
            </div>
        <% } %>
        <section class="pagination-row">
            <p>Total products: <%= totalProducts %></p>
            <form action="/" method="GET" class="pagination-form">
                <input type="hidden" name="page" value="1">
                <label for="itemsPerPage">Items per page</label>
                <select name="itemsPerPage" id="itemsPerPage" onchange="this.form.submit()">
                    <% allowedItemsPerPage.forEach(size => { %>
                        <option value="<%= size %>" <%= itemsPerPage === size ? 'selected' : '' %>><%= size %></option>
                    <% }) %>
                </select>
            </form>
            <div class="pagination-controls">
                <% if (hasPreviousPage) { %>
                    <a href="/?page=<%= previousPage %>&itemsPerPage=<%= itemsPerPage %>" class="btn">Previous</a>
                <% } %>
                <span>Page <%= currentPage %> of <%= totalPages %></span>
                <% if (hasNextPage) { %>
                    <a href="/?page=<%= nextPage %>&itemsPerPage=<%= itemsPerPage %>" class="btn">Next</a>
                <% } %>
            </div>
        </section>
    </main>
<%- include('../includes/end.ejs') %>